{
  "name": "statistic-chart-generator-admin-v2",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "analyze:stats": "ng build --stats-json && npx webpack-bundle-analyzer dist/$(node -p \"require('./package.json').name\")/stats.json",
    "analyze:source-maps": "ng build --source-map && npx source-map-explorer dist/$(node -p \"require('./package.json').name\")/*.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/router": "^21.2.14",
    "echarts": "^6.1.0",
    "highcharts": "^12.6.0",
    "marked": "^18.0.4",
    "ngx-markdown": "^21.3.0",
    "rxjs": "~7.8.0",
    "sql-formatter": "^15.8.1",
    "tslib": "^2.3.0",
    "uikit": "~3.22.4",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "less": "^4.2.0",
    "typescript": "~5.9.3"
  }
}
