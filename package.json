{
  "name": "statistic-chart-generator-admin-v2",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "analyze:stats": "ng build --stats-json && npx webpack-bundle-analyzer dist/$(node -p \"require('./package.json').name\")/stats.json",
    "analyze:source-maps": "ng build --source-map && npx source-map-explorer dist/$(node -p \"require('./package.json').name\")/*.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "highcharts": "^9.1.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uikit": "~3.22.4",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.21",
    "@types/echarts": "^4.9.13",
    "@types/jasmine": "~4.3.0",
    "@types/uikit": "^3.14.5",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.2.0",
    "typescript": "~5.8.3"
  }
}